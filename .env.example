# ── Telegram ────────────────────────────────────────────────
BOT_TOKEN=123456:your-telegram-bot-token
# Public HTTPS base URL where Telegram & Linear webhooks are delivered.
# In local dev use an ngrok/cloudflared tunnel, e.g. https://abcd.ngrok-free.app
PUBLIC_BASE_URL=https://your-public-host
# Random secret used to validate Telegram webhook calls
TELEGRAM_WEBHOOK_SECRET=change-me-random-string

# ── Linear OAuth (actor=app) ────────────────────────────────
# Create an OAuth application at https://linear.app/settings/api/applications
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
# Must exactly match the redirect URL registered in the Linear OAuth app:
#   ${PUBLIC_BASE_URL}/linear/oauth/callback
LINEAR_REDIRECT_URI=https://your-public-host/linear/oauth/callback
# Secret configured on the Linear webhook to verify incoming signatures
LINEAR_WEBHOOK_SECRET=

# ── Database / cache ────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://lineartg:lineartg@localhost:5432/lineartg
REDIS_URL=redis://localhost:6379/0

# ── App ─────────────────────────────────────────────────────
# Telegram user IDs that are bootstrap admins (PM). Comma-separated.
BOOTSTRAP_ADMIN_IDS=
DEFAULT_LANG=ru
LOG_LEVEL=INFO
# Local web server bind (behind the public reverse proxy / tunnel)
WEB_HOST=0.0.0.0
WEB_PORT=8080
